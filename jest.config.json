{
  "testEnvironment": "node",
  "testMatch": [
    "tests/**/*.test.js"
  ],
  "collectCoverage": true,
  "coverageDirectory": "coverage",
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  },
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/tests/"
  ]
}
